// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
}

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  password  String
  name      String?
  role      String   @default("member") // "admin" or "member"
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  prompts   Prompt[]
  projects  Project[]
}

model Category {
  id          String   @id @default(cuid())
  name        String   @unique
  description String?
  color       String   @default("#6366f1")
  createdAt   DateTime @default(now())
  prompts     Prompt[] @relation("PromptCategories")
}

model Prompt {
  id             String         @id @default(cuid())
  title          String
  aiTool         String
  promptText     String
  negativePrompt String?
  modelVersion   String?
  aspectRatio    String?
  beforeImage    String?        // Before/reference image (file path or URL)
  afterImage     String?        // Generated result image (file path or URL)
  settings       String?        // JSON string for additional settings
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt
  userId         String
  user           User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  categories     Category[]     @relation("PromptCategories")
  projectEntries ProjectEntry[]

  @@index([aiTool])
  @@index([createdAt])
}

model Project {
  id          String         @id @default(cuid())
  title       String
  description String?
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt
  userId      String
  user        User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  entries     ProjectEntry[]

  @@index([userId])
  @@index([createdAt])
}

model ProjectEntry {
  id         String         @id @default(cuid())
  notes      String?        // optional notes / context for this iteration
  promptText String?        // editable snapshot of the prompt used
  createdAt  DateTime       @default(now())
  updatedAt  DateTime       @updatedAt
  projectId  String
  project    Project        @relation(fields: [projectId], references: [id], onDelete: Cascade)
  promptId   String?        // optional FK to the source prompt in the library
  prompt     Prompt?        @relation(fields: [promptId], references: [id], onDelete: SetNull)
  images     ProjectImage[]

  @@index([projectId])
  @@index([createdAt])
  @@index([promptId])
}

model ProjectImage {
  id        String       @id @default(cuid())
  url       String
  type      String       // "input" | "result"
  order     Int          @default(0)
  createdAt DateTime     @default(now())
  entryId   String
  entry     ProjectEntry @relation(fields: [entryId], references: [id], onDelete: Cascade)

  @@index([entryId])
}
